# Server
HOST=0.0.0.0
PORT=8080
BASE_URL=http://localhost:8080

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/urlshortener

# Cassandra
CASSANDRA_NODES=127.0.0.1:9042
CASSANDRA_KEYSPACE=urlshortener
CASSANDRA_QUERY_TIMEOUT_MS=1000

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_POOL_MIN=8
REDIS_POOL_MAX=32
REDIS_POOL_TIMEOUT_MS=100
REDIS_CONNECT_TIMEOUT_MS=500
REDIS_COMMAND_TIMEOUT_MS=200

# Circuit Breaker
REDIS_CB_FAILURE_THRESHOLD=5
REDIS_CB_OPEN_DURATION_SECS=30

# Cache
STATS_CACHE_TTL_SECS=5

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECS=60

# ID Generation
ID_BATCH_SIZE=1000
FEISTEL_MASTER_KEY=16045690984833335486

# Logging
RUST_LOG=info
